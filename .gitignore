# ==============================================================================
# Weekwise — Combined .gitignore (Frontend + Backend)
# ==============================================================================

# ------------------------------------------------------------------------------
# OS & Editor
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# ------------------------------------------------------------------------------
# Angular / Node.js (frontend/)
# ------------------------------------------------------------------------------
node_modules/
dist/
tmp/
out-tsc/
.angular/
.sass-cache/
*.css.map
*.js.map

# npm / yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# Environment files with secrets
frontend/.env
frontend/.env.local

# Test & coverage
coverage/
.nyc_output/
karma-results/

# ------------------------------------------------------------------------------
# .NET / C# (backend/)
# ------------------------------------------------------------------------------
bin/
obj/

# NuGet
*.nupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# MSBuild
*.log
[Bb]uild[Ll]og.*

# Visual Studio
.vs/
*.VC.db
*.VC.VC.opendb
launchSettings.json

# SQLite database files (generated at runtime)
*.db
*.db-shm
*.db-wal

# EF Core migrations snapshot (keep migrations, ignore auto-generated)
# Uncomment below if you want to ignore migration snapshots
# **/Migrations/*.Designer.cs

# Publish output
publish/

# dotnet tool
.dotnet/
.config/

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# ------------------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig
